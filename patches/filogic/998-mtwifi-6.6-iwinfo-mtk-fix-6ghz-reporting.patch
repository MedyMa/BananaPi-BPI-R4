+static int mtk_get_assoc_bitrate(const char *dev, int *buf)
+{
+	char res[IWINFO_BUFSIZE] = { 0 };
+	struct iwinfo_assoclist_entry *e;
+	uint32_t rate;
+	int len = 0;
+	int best = 0;
+	int i;
+
+	if (mtk_get_assoclist(dev, res, &len) || len <= 0)
+		return -1;
+
+	for (i = 0; i < len; i += sizeof(struct iwinfo_assoclist_entry)) {
+		e = (struct iwinfo_assoclist_entry *)&res[i];
+
+		rate = e->tx_rate.rate;
+		if (rate > best)
+			best = rate;
+
+		rate = e->rx_rate.rate;
+		if (rate > best)
+			best = rate;
+	}
+
+	if (best <= 0)
+		return -1;
+
+	*buf = best;
+	return 0;
+}
