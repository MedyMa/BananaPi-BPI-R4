@@ -2748,6 +2751,32 @@
 
 	mutex_lock(&dev->mt76.mutex);
 	ret = mt7996_mcu_set_emlsr_mode(dev, vif, sta, eml_params);
+	mutex_unlock(&dev->mt76.mutex);
+
