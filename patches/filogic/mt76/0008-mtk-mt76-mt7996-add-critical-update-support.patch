From d956ba7f905a49e6eac2c25329bc695b7941a326 Mon Sep 17 00:00:00 2001
From: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
Date: Tue, 23 Apr 2024 15:22:24 +0800
Subject: [PATCH 08/95] mtk: mt76: mt7996: add critical update support

Add critical update support on top of 2ab64980.

This rebases the original BPI patch onto the current upstream mt76 tree,
preserving the CSA beacon sequencing, affiliated-link countdown updates,
and critical update TLVs needed by the vendor patch stack.

Signed-off-by: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
---
 mt76_connac_mcu.h |  2 ++
 mt7996/main.c     | 43 ++++++++++++++++++++++++++++++++++------
 mt7996/mcu.c      | 96 ++++++++++++++++++++++++++++++++++++++++++++++++++++++
 mt7996/mcu.h      | 29 ++++++++++++++++
 mt7996/mt7996.h   |  3 +++
 5 files changed, 163 insertions(+), 10 deletions(-)

diff --git a/mt76_connac_mcu.h b/mt76_connac_mcu.h
--- a/mt76_connac_mcu.h
+++ b/mt76_connac_mcu.h
@@ -1397,7 +1397,9 @@
 	UNI_BSS_INFO_MLD = 26,
 	UNI_BSS_INFO_PM_DISABLE = 27,
 	UNI_BSS_INFO_EHT = 30,
+	UNI_BSS_INFO_BCN_CRIT_UPDATE = 32,
 	UNI_BSS_INFO_MLD_LINK_OP = 36,
+	UNI_BSS_INFO_BCN_STA_PROF_CSA = 37,
 };
 
 enum {
diff --git a/mt7996/main.c b/mt7996/main.c
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -1014,7 +1014,11 @@
 		link->mt76.beacon_rates_idx =
 			mt7996_get_rates_table(phy, info, true, false);
 
-		mt7996_mcu_add_beacon(hw, vif, info, info->enable_beacon);
+		/* The CSA beacon will be set in channel_switch_beacon,
+		 * but beacon can be disabled during CSA for DFS channel.
+		 */
+		if (!info->enable_beacon || !info->csa_active)
+			mt7996_mcu_add_beacon(hw, vif, info, info->enable_beacon);
 	}
 
 	if (changed & (BSS_CHANGED_UNSOL_BCAST_PROBE_RESP |
@@ -1041,8 +1045,10 @@
 {
 	struct mt7996_dev *dev = mt7996_hw_dev(hw);
 	struct mt7996_phy *phy = mt7996_band_phy(dev, chandef->chan->band);
+	struct mt7996_vif *mvif = (struct mt7996_vif *)vif->drv_priv;
 	struct ieee80211_bss_conf *link_conf;
-	unsigned int link_id;
+	unsigned long valid_links = vif->valid_links ?: BIT(0);
+	unsigned int link_id, target_link = IEEE80211_LINK_UNSPECIFIED;
 
 	mutex_lock(&dev->mt76.mutex);
 
@@ -1058,17 +1064,48 @@
 		if (link_phy != phy)
 			continue;
 
-		/* Reset beacon when channel switch triggered during CAC to let
-		 * FW correctly perform CSA countdown
-		 */
-		if (!cfg80211_reg_can_beacon(hw->wiphy, &phy->mt76->chandef,
-					     vif->type))
+		target_link = link_id;
+		break;
+	}
+
+	if (target_link == IEEE80211_LINK_UNSPECIFIED)
+		goto out;
+
+	if (!mvif->cs_ready_links)
+		mvif->cs_link_id = target_link;
+
+	mvif->cs_ready_links |= BIT(target_link);
+	if (mvif->cs_ready_links != valid_links)
+		goto out;
+
+	link_id = mvif->cs_link_id;
+	do {
+		struct mt7996_vif_link *link;
+
+		valid_links &= ~BIT(link_id);
+		link_conf = link_conf_dereference_protected(vif, link_id);
+		link = mt7996_vif_link(dev, vif, link_id);
+		if (!link_conf || !link || mt7996_vif_link_phy(link) != phy)
+			goto fail;
+
+		if (link_id == mvif->cs_link_id &&
+		    !cfg80211_reg_can_beacon(hw->wiphy, &phy->mt76->chandef, vif->type))
 			mt7996_mcu_add_beacon(hw, vif, link_conf, false);
 
 		mt7996_mcu_add_beacon(hw, vif, link_conf, true);
-		break;
-	}
 
+		if (!valid_links)
+			break;
+		link_id = __ffs(valid_links);
+	} while (true);
+
+out:
+	mutex_unlock(&dev->mt76.mutex);
+	return;
+fail:
+	mvif->cs_ready_links = 0;
+	mvif->cs_link_id = IEEE80211_LINK_UNSPECIFIED;
+	dev_err(dev->mt76.dev, "link %u: failed to switch beacon\n", link_id);
 	mutex_unlock(&dev->mt76.mutex);
 }
 
diff --git a/mt7996/mcu.c b/mt7996/mcu.c
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -440,7 +440,15 @@
 	if (!link_conf || !link_conf->csa_active)
 		return;
 
+	mvif->cs_ready_links = 0;
+	mvif->cs_link_id = IEEE80211_LINK_UNSPECIFIED;
 	ieee80211_csa_finish(vif, link_conf->link_id);
+	/* remove CSA for affiliated links */
+	for_each_set_bit(link_id, &valid_links, IEEE80211_MLD_MAX_NUM_LINKS) {
+		if (link_id == link_conf->link_id)
+			continue;
+		ieee80211_csa_finish(vif, link_id);
+	}
 }
 
 static void
@@ -3147,6 +3155,86 @@
 	}
 }
 
+static bool
+mt7996_mcu_beacon_is_cu_link(struct sk_buff *skb, struct mt7996_vif_link *link,
+			     u16 tail_offset)
+{
+	const struct element *elem;
+	u8 *beacon_tail = skb->data + tail_offset;
+	bool has_ml_ie = false;
+	int bpcc;
+
+	for_each_element_extid(elem, WLAN_EID_EXT_EHT_MULTI_LINK,
+			       beacon_tail, skb->len - tail_offset)
+		if (ieee80211_mle_type_ok(elem->data + 1,
+					  IEEE80211_ML_CONTROL_TYPE_BASIC,
+					  elem->datalen - 1)) {
+			has_ml_ie = true;
+			break;
+		}
+
+	if (!has_ml_ie)
+		return false;
+
+	bpcc = ieee80211_mle_get_bss_param_ch_cnt(elem->data + 1);
+	if (bpcc < 0 || bpcc == link->bpcc)
+		return false;
+
+	link->bpcc = bpcc;
+	return true;
+}
+
+static void
+mt7996_mcu_beacon_crit_update(struct sk_buff *rskb, struct sk_buff *skb,
+			      struct ieee80211_bss_conf *conf,
+			      struct mt7996_vif_link *link,
+			      struct ieee80211_mutable_offsets *offs)
+{
+	struct ieee80211_mgmt *mgmt = (void *)skb->data;
+	struct bss_bcn_crit_update_tlv *crit;
+	struct tlv *tlv;
+	u16 capab_info = le16_to_cpu(mgmt->u.beacon.capab_info);
+
+	if (!ieee80211_vif_is_mld(conf->vif) ||
+	    !(capab_info & WLAN_CAPABILITY_PBCC))
+		return;
+
+	tlv = mt7996_mcu_add_uni_tlv(rskb, UNI_BSS_INFO_BCN_CRIT_UPDATE, sizeof(*crit));
+	crit = (struct bss_bcn_crit_update_tlv *)tlv;
+	crit->bss_bitmap = cpu_to_le32(BIT(0));
+	if (!mt7996_mcu_beacon_is_cu_link(skb, link, offs->tim_offset))
+		crit->bypass_seq_bitmap = cpu_to_le32(BIT(0));
+	else
+		crit->bypass_seq_bitmap = cpu_to_le32(0);
+	crit->tim_ie_pos[0] = cpu_to_le16(offs->tim_offset);
+	crit->cap_info_ie_pos[0] = cpu_to_le16(offsetof(struct ieee80211_mgmt, u.beacon.capab_info));
+}
+
+static void
+mt7996_mcu_beacon_sta_prof_csa(struct mt7996_dev *dev,
+			       struct sk_buff *rskb,
+			       struct ieee80211_bss_conf *conf,
+			       struct ieee80211_mutable_offsets *offs)
+{
+	struct ieee80211_vif *vif = conf->vif;
+	struct mt7996_vif *mvif = (struct mt7996_vif *)vif->drv_priv;
+	struct mt7996_vif_link *cs_link;
+	struct bss_bcn_sta_prof_cntdwn_tlv *sta_prof;
+	struct tlv *tlv;
+
+	if (!ieee80211_vif_is_mld(vif) || !offs->sta_prof_cntdwn_offs[0])
+		return;
+
+	cs_link = mt7996_vif_link(dev, vif, mvif->cs_link_id);
+	if (!cs_link)
+		return;
+
+	tlv = mt7996_mcu_add_uni_tlv(rskb, UNI_BSS_INFO_BCN_STA_PROF_CSA, sizeof(*sta_prof));
+	sta_prof = (struct bss_bcn_sta_prof_cntdwn_tlv *)tlv;
+	sta_prof->sta_prof_csa_offs = cpu_to_le16(offs->sta_prof_cntdwn_offs[0] - 4);
+	sta_prof->cs_bss_idx = cs_link->mt76.idx;
+}
+
 static void
 mt7996_mcu_beacon_cont(struct mt7996_dev *dev,
 		       struct ieee80211_bss_conf *link_conf,
@@ -3241,6 +3329,8 @@
 	if (link_conf->bssid_indicator)
 		mt7996_mcu_beacon_mbss(rskb, skb, bcn, &offs);
 	mt7996_mcu_beacon_cntdwn(rskb, skb, &offs, link_conf->csa_active);
+	mt7996_mcu_beacon_sta_prof_csa(dev, rskb, link_conf, &offs);
+	mt7996_mcu_beacon_crit_update(rskb, skb, link_conf, link, &offs);
 out:
 	dev_kfree_skb(skb);
 	return mt76_mcu_skb_send_msg(&dev->mt76, rskb,
diff --git a/mt7996/mcu.h b/mt7996/mcu.h
--- a/mt7996/mcu.h
+++ b/mt7996/mcu.h
@@ -502,6 +502,23 @@
 	__le16 offset[MAX_BEACON_NUM];
 } __packed __aligned(4);
 
+struct bss_bcn_crit_update_tlv {
+	__le16 tag;
+	__le16 len;
+	__le32 bss_bitmap;
+	__le32 bypass_seq_bitmap;
+	__le16 tim_ie_pos[32];
+	__le16 cap_info_ie_pos[32];
+} __packed;
+
+struct bss_bcn_sta_prof_cntdwn_tlv {
+	__le16 tag;
+	__le16 len;
+	__le16 sta_prof_csa_offs;
+	u8 cs_bss_idx;
+	u8 pkt_content[9];
+} __packed;
+
 struct bss_txcmd_tlv {
 	__le16 tag;
 	__le16 len;
@@ -948,10 +965,12 @@
 					 sizeof(struct tlv))
 
 #define MT7996_BEACON_UPDATE_SIZE	(sizeof(struct bss_req_hdr) +		\
-					 sizeof(struct bss_bcn_content_tlv) +	\
-					 4 + MT_TXD_SIZE +			\
-					 sizeof(struct bss_bcn_cntdwn_tlv) +	\
-					 sizeof(struct bss_bcn_mbss_tlv))
+				 sizeof(struct bss_bcn_content_tlv) +	\
+				 4 + MT_TXD_SIZE +			\
+				 sizeof(struct bss_bcn_cntdwn_tlv) +	\
+				 sizeof(struct bss_bcn_mbss_tlv) +	\
+				 sizeof(struct bss_bcn_crit_update_tlv) +	\
+				 sizeof(struct bss_bcn_sta_prof_cntdwn_tlv))
 #define MT7996_MAX_BSS_OFFLOAD_SIZE	2048
 #define MT7996_MAX_BEACON_SIZE		(MT7996_MAX_BSS_OFFLOAD_SIZE - \
 					 MT7996_BEACON_UPDATE_SIZE)
diff --git a/mt7996/mt7996.h b/mt7996/mt7996.h
--- a/mt7996/mt7996.h
+++ b/mt7996/mt7996.h
@@ -279,6 +279,7 @@
 	struct cfg80211_bitrate_mask bitrate_mask;
 
 	u8 mld_idx;
+	u8 bpcc;
 };
 
 struct mt7996_vif_link_info {
@@ -293,6 +294,8 @@
 
 	u8 mld_group_idx;
 	u8 mld_remap_idx;
+	u8 cs_link_id;
+	u16 cs_ready_links;
 };
 
