+	TP_ARGS(dev, errno, data, len, wlan_id, msdu),
+
+	TP_STRUCT__entry(
+		DEV_ENTRY
+		__field(u8, errno)
+		__field(size_t, len)
+		__dynamic_array(u8, data, len)
+		__field(u16, wlan_id)
+		__field(u32, msdu)
+	),
+
+	TP_fast_assign(
+		DEV_ASSIGN(dev->mphy.hw->wiphy);
+		__entry->errno = errno;
+		__entry->len = len;
+		memcpy(__get_dynamic_array(data), data, len);
+		__entry->wlan_id = wlan_id;
+		__entry->msdu = msdu;
