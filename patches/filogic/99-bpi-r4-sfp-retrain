#!/bin/sh

[ "$ACTION" = ifup ] || [ "$ACTION" = ifupdate ] || exit 0

. /lib/functions/system.sh

case "$(board_name)" in
	bananapi,bpi-r4|bananapi,bpi-r4-2g5|bananapi,bpi-r4-lite|bananapi,bpi-r4-poe)
		;;
	*)
		exit 0
		;;
esac

command -v ethtool >/dev/null 2>&1 || exit 0

ifaces="sfp-wan sfp-lan eth2 eth1"

(
	lock_dir="/var/run/bpi-r4-sfp-retrain.lock"
	mkdir "$lock_dir" 2>/dev/null || exit 0
	trap 'rmdir "$lock_dir" 2>/dev/null' EXIT INT TERM

	wait_round=0
	while [ "$wait_round" -lt 10 ]; do
		found_iface=0
		for iface in $ifaces; do
			if [ -d "/sys/class/net/$iface" ]; then
				found_iface=1
				break
			fi
		done

		[ "$found_iface" -eq 1 ] && break
		sleep 3
		wait_round=$((wait_round + 1))
	done

	if [ "$found_iface" -ne 1 ]; then
		logger -t bpi-r4-sfp-retrain "no SFP netdev present after ${ACTION:-unknown}, skipping retrain"
		exit 0
	fi

	retry=1
	while [ "$retry" -le 4 ]; do
		pending_iface=0

		for iface in $ifaces; do
			[ -d "/sys/class/net/$iface" ] || continue
			[ "$(cat "/sys/class/net/$iface/carrier" 2>/dev/null)" = "1" ] && continue

			pending_iface=1
			logger -t bpi-r4-sfp-retrain "carrier down on $iface after ${ACTION:-unknown}, retraining (attempt $retry)"
			ethtool -r "$iface" >/dev/null 2>&1 || true
			ip link set dev "$iface" down >/dev/null 2>&1 || true
			sleep 1
			ip link set dev "$iface" up >/dev/null 2>&1 || true
		done

		[ "$pending_iface" -eq 0 ] && exit 0
		[ "$retry" -ge 4 ] && break
		sleep 5
		retry=$((retry + 1))
	done
) &